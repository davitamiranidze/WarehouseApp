{
  "name": "WarehouseApp",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "jest": "^30.4.2",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-stockitems": "cds watch --open warehouse.stockitems/index.html?sap-ui-xx-viewCache=false --livereload false",
    "test": "jest",
    "watch-products": "cds watch --open warehouse.products/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy WarehouseApp --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "alice": {
              "roles": [
                "Viewer"
              ]
            },
            "admin": {
              "roles": [
                "Admin",
                "Viewer"
              ]
            }
          }
        }
      },
      "[test]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "alice": {
              "roles": [
                "Viewer"
              ]
            },
            "admin": {
              "roles": [
                "Admin",
                "Viewer"
              ]
            }
          }
        }
      },
      "[production]": {
        "db": "hana",
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/stockitems",
    "app/products"
  ]
}
